{
  "$description": "Contrato de tokens · formato W3C DTCG (2025.10). Tres niveles: primitivo → semántico → componente. Los componentes NUNCA referencian primitivos directamente.",
  "primitive": {
    "color": {
      "$type": "color",
      "neutral": {
        "0":   { "$value": "#FFFFFF" },
        "50":  { "$value": "#F6F7F9" },
        "100": { "$value": "#ECEEF2" },
        "200": { "$value": "#D8DCE3" },
        "400": { "$value": "#9AA1AB" },
        "600": { "$value": "#5A616B" },
        "800": { "$value": "#2A2F37" },
        "900": { "$value": "#14161A" }
      },
      "blue": {
        "50":  { "$value": "#EEEDFC" },
        "500": { "$value": "#4F46E5" },
        "700": { "$value": "#312BA6" }
      },
      "amber": { "500": { "$value": "#C2620A" } },
      "green": { "500": { "$value": "#1E7A54" } },
      "red":   { "500": { "$value": "#C0362C" } }
    },
    "space": {
      "$type": "dimension",
      "1": { "$value": { "value": 4,  "unit": "px" } },
      "2": { "$value": { "value": 8,  "unit": "px" } },
      "3": { "$value": { "value": 12, "unit": "px" } },
      "4": { "$value": { "value": 16, "unit": "px" } },
      "6": { "$value": { "value": 24, "unit": "px" } }
    },
    "radius": {
      "$type": "dimension",
      "sm": { "$value": { "value": 6,  "unit": "px" } },
      "md": { "$value": { "value": 10, "unit": "px" } }
    },
    "font": {
      "family": {
        "$type": "fontFamily",
        "sans": { "$value": "Inter, system-ui, sans-serif" },
        "mono": { "$value": "'JetBrains Mono', ui-monospace, monospace" }
      },
      "size": {
        "$type": "dimension",
        "sm": { "$value": { "value": 12, "unit": "px" } },
        "md": { "$value": { "value": 14, "unit": "px" } },
        "lg": { "$value": { "value": 18, "unit": "px" } }
      },
      "weight": {
        "$type": "fontWeight",
        "regular": { "$value": 400 },
        "medium":  { "$value": 500 }
      }
    }
  },

  "semantic": {
    "color": {
      "$type": "color",
      "bg": {
        "base":   { "$value": "{primitive.color.neutral.0}",  "$description": "Fondo de superficie principal." },
        "subtle": { "$value": "{primitive.color.neutral.50}" }
      },
      "text": {
        "primary":   { "$value": "{primitive.color.neutral.900}" },
        "muted":     { "$value": "{primitive.color.neutral.600}" },
        "on-accent": { "$value": "{primitive.color.neutral.0}" }
      },
      "border": {
        "default": { "$value": "{primitive.color.neutral.200}" }
      },
      "accent":        { "$value": "{primitive.color.blue.500}" },
      "accent-strong": { "$value": "{primitive.color.blue.700}" },
      "feedback": {
        "danger": { "$value": "{primitive.color.red.500}" }
      }
    },
    "space": {
      "$type": "dimension",
      "inset-sm": { "$value": "{primitive.space.2}" },
      "inset-md": { "$value": "{primitive.space.4}" },
      "gap-sm":   { "$value": "{primitive.space.2}" }
    },
    "radius": {
      "$type": "dimension",
      "control": { "$value": "{primitive.radius.sm}" },
      "card":    { "$value": "{primitive.radius.md}" }
    }
  },

  "component": {
    "button": {
      "primary": {
        "bg":     { "$type": "color",     "$value": "{semantic.color.accent}" },
        "text":   { "$type": "color",     "$value": "{semantic.color.text.on-accent}" },
        "radius": { "$type": "dimension", "$value": "{semantic.radius.control}" }
      }
    },
    "card": {
      "bg":     { "$type": "color",     "$value": "{semantic.color.bg.base}" },
      "border": { "$type": "color",     "$value": "{semantic.color.border.default}" },
      "radius": { "$type": "dimension", "$value": "{semantic.radius.card}" }
    }
  }
}
